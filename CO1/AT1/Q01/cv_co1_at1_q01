import cv2
import matplotlib.pyplot as plt
from google.colab import files

# Upload image
uploaded = files.upload()

# Get uploaded filename
filename = list(uploaded.keys())[0]

# Read the image
image = cv2.imread(filename)

# Check if image is loaded
if image is None:
    raise Exception("Image could not be loaded!")

# Convert BGR to RGB
image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)

# Simulate improper sampling (low resolution)
low_res = cv2.resize(image, (100, 100), interpolation=cv2.INTER_AREA)

# Enlarge back to original size (blurred image)
blurred = cv2.resize(
    low_res,
    (image.shape[1], image.shape[0]),
    interpolation=cv2.INTER_LINEAR
)

# Correct using Bicubic interpolation
corrected = cv2.resize(
    low_res,
    (image.shape[1], image.shape[0]),
    interpolation=cv2.INTER_CUBIC
)

# Display results
plt.figure(figsize=(15,5))

plt.subplot(1,3,1)
plt.imshow(image)
plt.title("Original Image")
plt.axis("off")

plt.subplot(1,3,2)
plt.imshow(blurred)
plt.title("Improper Sampling")
plt.axis("off")

plt.subplot(1,3,3)
plt.imshow(corrected)
plt.title("Corrected Image")
plt.axis("off")

plt.show()
